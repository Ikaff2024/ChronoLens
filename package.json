{
  "name": "chronolens-osint",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @chronolens/api",
    "db:push": "npm run db:push --workspace @chronolens/api",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace @chronolens/api"
    ,"smoke:http": "node scripts/smoke-http.mjs"
    ,"benchmark:postgres": "node scripts/benchmark-postgres.mjs"
  },
  "engines": {
    "node": ">=22"
  }
}
